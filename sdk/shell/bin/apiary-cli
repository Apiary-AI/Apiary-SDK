#!/usr/bin/env bash
# apiary-cli — Command-line wrapper for the Apiary Shell SDK.
#
# Usage:
#   apiary-cli <command> [options]
#
# Commands:
#   register      Register a new agent
#   login         Authenticate an existing agent
#   logout        Revoke the current token
#   me            Show current agent profile
#   heartbeat     Send heartbeat
#   status        Update agent status
#   drain         Enter drain mode
#   undrain       Exit drain mode
#   drain-status  Show drain status
#   key-rotate    Rotate API key
#   key-revoke    Revoke previous (grace) key
#   key-status    Show key rotation status
#   task-create   Create a task
#   task-poll     Poll for available tasks
#   task-claim    Claim a pending task
#   task-progress Update task progress
#   task-complete Complete a task
#   task-fail     Fail a task
#   schedule-list     List task schedules
#   schedule-get      Get a task schedule
#   schedule-create   Create a task schedule
#   schedule-update   Update a task schedule
#   schedule-delete   Delete a task schedule
#   schedule-pause    Pause a task schedule
#   schedule-resume   Resume a task schedule
#   knowledge-list    List knowledge entries
#   knowledge-search  Search knowledge entries
#   knowledge-get     Get a knowledge entry
#   knowledge-create  Create a knowledge entry
#   knowledge-update  Update a knowledge entry
#   knowledge-delete  Delete a knowledge entry
#   version       Show SDK version
#
# Environment:
#   APIARY_BASE_URL   API base URL (required)
#   APIARY_TOKEN      Bearer token (or use register/login first)
#   APIARY_TIMEOUT    Request timeout in seconds (default: 30)
#   APIARY_DEBUG      Set to 1 for verbose output

set -euo pipefail

# Resolve SDK path relative to this script
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SDK_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"

# shellcheck source=../src/apiary-sdk.sh
source "${SDK_DIR}/src/apiary-sdk.sh"

_cli_usage() {
    echo "Usage: apiary-cli <command> [options]"
    echo ""
    echo "Commands:"
    echo "  register         Register a new agent"
    echo "  login            Authenticate an existing agent"
    echo "  logout           Revoke the current token"
    echo "  me               Show current agent profile"
    echo "  heartbeat        Send heartbeat"
    echo "  status           Update agent status"
    echo "  drain            Enter drain mode"
    echo "  undrain          Exit drain mode"
    echo "  drain-status     Show drain status"
    echo "  key-rotate       Rotate API key"
    echo "  key-revoke       Revoke previous (grace) key"
    echo "  key-status       Show key rotation status"
    echo "  task-create      Create a task"
    echo "  task-poll        Poll for available tasks"
    echo "  task-claim       Claim a pending task"
    echo "  task-progress    Update task progress"
    echo "  task-complete    Complete a task"
    echo "  task-fail        Fail a task"
    echo "  schedule-list    List task schedules"
    echo "  schedule-get     Get a task schedule"
    echo "  schedule-create  Create a task schedule"
    echo "  schedule-update  Update a task schedule"
    echo "  schedule-delete  Delete a task schedule"
    echo "  schedule-pause   Pause a task schedule"
    echo "  schedule-resume  Resume a task schedule"
    echo "  knowledge-list   List knowledge entries"
    echo "  knowledge-search Search knowledge entries"
    echo "  knowledge-get    Get a knowledge entry"
    echo "  knowledge-create Create a knowledge entry"
    echo "  knowledge-update Update a knowledge entry"
    echo "  knowledge-delete Delete a knowledge entry"
    echo "  version          Show SDK version"
    echo ""
    echo "Environment:"
    echo "  APIARY_BASE_URL  API base URL (required)"
    echo "  APIARY_TOKEN     Bearer token"
    echo "  APIARY_TIMEOUT   Request timeout in seconds (default: 30)"
    echo "  APIARY_DEBUG     Set to 1 for verbose output"
}

_cli_register_usage() {
    echo "Usage: apiary-cli register -n NAME -h HIVE_ID -s SECRET [-a APIARY_ID] [-t TYPE] [-c CAPABILITIES_JSON] [-m METADATA_JSON]"
}

_cli_login_usage() {
    echo "Usage: apiary-cli login -i AGENT_ID -s SECRET"
}

_cli_task_create_usage() {
    echo "Usage: apiary-cli task-create HIVE_ID -t TYPE [-p PRIORITY] [-a TARGET_AGENT_ID] [-c TARGET_CAPABILITY] [-d PAYLOAD_JSON] [-T TIMEOUT] [-r MAX_RETRIES] [-P PARENT_TASK_ID] [-x CONTEXT_REFS_JSON] [-g GUARANTEE] [-e EXPIRES_AT] [-I INVOKE_INSTRUCTIONS] [-X INVOKE_CONTEXT_JSON]"
}

if [[ $# -lt 1 ]]; then
    _cli_usage
    exit 1
fi

# Check dependencies
apiary_check_deps || exit $?

# Load persisted token if APIARY_TOKEN is not already set
apiary_load_token

command="$1"
shift

case "$command" in
    register)
        [[ $# -eq 0 ]] && { _cli_register_usage; exit 1; }
        apiary_register "$@"
        apiary_save_token
        ;;
    login)
        [[ $# -eq 0 ]] && { _cli_login_usage; exit 1; }
        apiary_login "$@"
        apiary_save_token
        ;;
    logout)
        _logout_rc=0
        apiary_logout || _logout_rc=$?
        apiary_clear_token_file
        [[ $_logout_rc -ne 0 ]] && exit "$_logout_rc"
        ;;
    me)
        apiary_me
        ;;
    heartbeat)
        apiary_heartbeat "$@"
        ;;
    status)
        if [[ $# -lt 1 ]]; then
            echo "Usage: apiary-cli status STATUS" >&2
            exit 1
        fi
        apiary_update_status "$1"
        ;;
    drain)
        apiary_enter_drain "$@"
        ;;
    undrain)
        apiary_exit_drain
        ;;
    drain-status)
        apiary_drain_status
        ;;
    key-rotate)
        [[ $# -eq 0 ]] && { echo "Usage: apiary-cli key-rotate -s NEW_SECRET [-g GRACE_PERIOD_MINUTES]" >&2; exit 1; }
        apiary_rotate_key "$@"
        apiary_save_token
        ;;
    key-revoke)
        apiary_revoke_previous_key
        ;;
    key-status)
        apiary_key_status
        ;;
    task-create)
        if [[ $# -lt 1 ]]; then
            _cli_task_create_usage
            exit 1
        fi
        apiary_create_task "$@"
        ;;
    task-poll)
        if [[ $# -lt 1 ]]; then
            echo "Usage: apiary-cli task-poll HIVE_ID [-c CAPABILITY] [-l LIMIT]" >&2
            exit 1
        fi
        apiary_poll_tasks "$@"
        ;;
    task-claim)
        if [[ $# -lt 2 ]]; then
            echo "Usage: apiary-cli task-claim HIVE_ID TASK_ID" >&2
            exit 1
        fi
        apiary_claim_task "$@"
        ;;
    task-progress)
        if [[ $# -lt 2 ]]; then
            echo "Usage: apiary-cli task-progress HIVE_ID TASK_ID -p PROGRESS [-m MESSAGE]" >&2
            exit 1
        fi
        apiary_update_progress "$@"
        ;;
    task-complete)
        if [[ $# -lt 2 ]]; then
            echo "Usage: apiary-cli task-complete HIVE_ID TASK_ID [-r RESULT_JSON] [-m MESSAGE]" >&2
            exit 1
        fi
        apiary_complete_task "$@"
        ;;
    task-fail)
        if [[ $# -lt 2 ]]; then
            echo "Usage: apiary-cli task-fail HIVE_ID TASK_ID [-e ERROR_JSON] [-m MESSAGE]" >&2
            exit 1
        fi
        apiary_fail_task "$@"
        ;;
    schedule-list)
        if [[ $# -lt 1 ]]; then
            echo "Usage: apiary-cli schedule-list HIVE_ID [-s STATUS]" >&2
            exit 1
        fi
        apiary_list_schedules "$@"
        ;;
    schedule-get)
        if [[ $# -lt 2 ]]; then
            echo "Usage: apiary-cli schedule-get HIVE_ID SCHEDULE_ID" >&2
            exit 1
        fi
        apiary_get_schedule "$@"
        ;;
    schedule-create)
        if [[ $# -lt 1 ]]; then
            echo "Usage: apiary-cli schedule-create HIVE_ID -n NAME -g TRIGGER_TYPE -t TASK_TYPE [...]" >&2
            exit 1
        fi
        apiary_create_schedule "$@"
        ;;
    schedule-update)
        if [[ $# -lt 2 ]]; then
            echo "Usage: apiary-cli schedule-update HIVE_ID SCHEDULE_ID [-n NAME] [-g TRIGGER_TYPE] [...]" >&2
            exit 1
        fi
        apiary_update_schedule "$@"
        ;;
    schedule-delete)
        if [[ $# -lt 2 ]]; then
            echo "Usage: apiary-cli schedule-delete HIVE_ID SCHEDULE_ID" >&2
            exit 1
        fi
        apiary_delete_schedule "$@"
        ;;
    schedule-pause)
        if [[ $# -lt 2 ]]; then
            echo "Usage: apiary-cli schedule-pause HIVE_ID SCHEDULE_ID" >&2
            exit 1
        fi
        apiary_pause_schedule "$@"
        ;;
    schedule-resume)
        if [[ $# -lt 2 ]]; then
            echo "Usage: apiary-cli schedule-resume HIVE_ID SCHEDULE_ID" >&2
            exit 1
        fi
        apiary_resume_schedule "$@"
        ;;
    knowledge-list)
        if [[ $# -lt 1 ]]; then
            echo "Usage: apiary-cli knowledge-list HIVE_ID [-k KEY] [-s SCOPE] [-l LIMIT]" >&2
            exit 1
        fi
        apiary_list_knowledge "$@"
        ;;
    knowledge-search)
        if [[ $# -lt 1 ]]; then
            echo "Usage: apiary-cli knowledge-search HIVE_ID [-q QUERY] [-s SCOPE] [-l LIMIT]" >&2
            exit 1
        fi
        apiary_search_knowledge "$@"
        ;;
    knowledge-get)
        if [[ $# -lt 2 ]]; then
            echo "Usage: apiary-cli knowledge-get HIVE_ID ENTRY_ID" >&2
            exit 1
        fi
        apiary_get_knowledge "$@"
        ;;
    knowledge-create)
        if [[ $# -lt 1 ]]; then
            echo "Usage: apiary-cli knowledge-create HIVE_ID -k KEY -v VALUE_JSON [-s SCOPE] [-V VISIBILITY] [-t TTL]" >&2
            exit 1
        fi
        apiary_create_knowledge "$@"
        ;;
    knowledge-update)
        if [[ $# -lt 2 ]]; then
            echo "Usage: apiary-cli knowledge-update HIVE_ID ENTRY_ID -v VALUE_JSON [-V VISIBILITY] [-t TTL]" >&2
            exit 1
        fi
        apiary_update_knowledge "$@"
        ;;
    knowledge-delete)
        if [[ $# -lt 2 ]]; then
            echo "Usage: apiary-cli knowledge-delete HIVE_ID ENTRY_ID" >&2
            exit 1
        fi
        apiary_delete_knowledge "$@"
        ;;
    rate-limit-status)
        apiary_rate_limit_status
        ;;
    rate-limit-update)
        [[ $# -eq 0 ]] && { echo "Usage: apiary-cli rate-limit-update -l LIMIT (or -l null)" >&2; exit 1; }
        apiary_update_rate_limit "$@"
        ;;
    version)
        echo "apiary-sdk ${APIARY_SDK_VERSION}"
        ;;
    help|--help|-h)
        _cli_usage
        ;;
    *)
        echo "Unknown command: $command" >&2
        _cli_usage >&2
        exit 1
        ;;
esac
